#!/bin/zsh

BOLD='\033[1m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
RESET='\033[0m'

step=0

progress() {
  step=$((step + 1))
  local bar="" i=1
  while (( i <= total )); do
    (( i <= step )) && bar+="=" || bar+=" "
    i=$((i + 1))
  done
  echo -e "\n${CYAN}[${bar}] ${step}/${total}${RESET}  ${BOLD}${1}${RESET}"
}

# MACOS
if [[ "$OSTYPE" == "darwin"* ]]; then
  total=7

  progress "Brew: update"
  brew update

  brew_outdated=$(brew outdated --verbose)

  progress "Brew: upgrade"
  brew upgrade

  if [[ -n "$brew_outdated" ]]; then
    echo -e "\nBrew: updated packages"
    echo "$brew_outdated"
  else
    echo -e "\nBrew: nothing to update"
  fi

  progress "Brew: cleanup"
  brew cleanup -s --prune-prefix

  progress "Brew: doctor"
  brew doctor

  progress "OMZ: update"
  omz update

  progress "PNPM: update"
  pnpm self-update

  progress "Yarn: cache clean"
  yarn cache clean

  echo -e "\n${GREEN}Done.${RESET}"

# FEDORA
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
  total=6

  dnf_updates=$(sudo dnf list updates 2>/dev/null)

  progress "Updating Fedora (DNF)"
  sudo dnf update -y

  if [[ -n "$dnf_updates" ]]; then
    echo -e "\nDNF: updated packages"
    echo "$dnf_updates"
  fi

  progress "Cleaning Fedora (DNF)"
  sudo dnf autoremove -y

  progress "Updating Snap"
  sudo snap refresh

  progress "Updating Flatpak"
  sudo flatpak update -y

  progress "Updating Oh-My-ZSH"
  omz update

  progress "Updating Neovim"
  nvim --headless "+Lazy! sync" +qa

  echo -e "\n${GREEN}Done.${RESET}"
fi

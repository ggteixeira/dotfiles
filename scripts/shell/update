#!/bin/zsh

BOLD='\033[1m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
RESET='\033[0m'

step=0

progress() {
  step=$((step + 1))
  local filled=$((step * 20 / total))
  local remainder=$((20 - filled))
  printf -v BAR "%-${filled}s" ""
  BAR="${BAR// /█}"
  printf -v EMPTY "%-${remainder}s" ""
  EMPTY="${EMPTY// /░}"
  echo -e "\n${CYAN}[${BAR}${EMPTY}] $((step * 100 / total))%% (${step}/${total})${RESET}  ${BOLD}${1}${RESET}"
}

# MACOS
if [[ "$OSTYPE" == "darwin"* ]]; then
  total=13

  progress "Dotfiles: update"
  git -C ~/.dotfiles pull

  progress "Brew: update"
  brew update

  brew_outdated=$(brew outdated --verbose)

  progress "Brew: upgrade"
  brew upgrade --greedy

  if [[ -n "$brew_outdated" ]]; then
    echo -e "\nBrew: updated packages"
    echo "$brew_outdated"
  else
    echo -e "\nBrew: nothing to update"
  fi

  progress "Brew: cleanup"
  brew cleanup -s --prune-prefix

  progress "Brew: autoremove"
  brew autoremove

  progress "Brew: doctor"
  brew doctor

  progress "OMZ: update"
  ZSH="$HOME/.oh-my-zsh" zsh "$HOME/.oh-my-zsh/tools/upgrade.sh"

  progress "PNPM: self-update"
  pnpm self-update

  progress "PNPM: update global packages"
  pnpm update -g

  progress "Neovim: sync plugins"
  nvim --headless "+Lazy! sync" +qa &>/dev/null

  progress "gh: upgrade extensions"
  gh extension upgrade --all

  progress "mas: upgrade"
  MAS_NO_AUTO_INDEX=1 mas upgrade

  progress "tldr: update"
  tldr --update

  echo -e "\n${GREEN}Done.${RESET}"
fi

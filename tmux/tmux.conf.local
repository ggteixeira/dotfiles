# Oh my tmux! local configuration
# https://github.com/gpakosz/.tmux

# -- bindings ------------------------------------------------------------------

tmux_conf_preserve_stock_bindings=false

# -- session creation ----------------------------------------------------------

tmux_conf_new_session_prompt=true
tmux_conf_new_session_retain_current_path=false

# -- windows & pane creation ---------------------------------------------------

tmux_conf_new_window_retain_current_path=true
tmux_conf_new_window_reconnect_ssh=true
tmux_conf_new_pane_retain_current_path=true
tmux_conf_new_pane_reconnect_ssh=true

# -- display -------------------------------------------------------------------

tmux_conf_24b_colour=true

# -- palette: gruvbox dark -----------------------------------------------------

_gb_bg0="#282828"        # dark0      — main background
_gb_bg0s="#32302f"       # dark0_soft — inactive pane dimming
_gb_bg1="#3c3836"        # dark1      — borders, secondary backgrounds
_gb_fg1="#ebdbb2"        # fg1        — light foreground
_gb_fg2="#d5c4a1"        # fg2        — last-window tab foreground
_gb_fg4="#a89984"        # fg4        — muted foreground
_gb_blue="#83a598"       # blue       — accent
_gb_yellow="#fabd2f"     # yellow     — messages, mode indicator
_gb_orange="#fe8019"     # orange     — session badge
_gb_green="#8ec07c"      # green      — active window tab
_gb_red="#fb4934"        # red        — prefix indicator

# -- theming: gruvbox dark -----------------------------------------------------

tmux_conf_theme=enabled

tmux_conf_theme_colour_1="$_gb_bg0"    # bg (dark0)
tmux_conf_theme_colour_2="$_gb_bg1"    # bg1 (borders, inactive bg)
tmux_conf_theme_colour_3="$_gb_fg4"    # fg4 (muted text)
tmux_conf_theme_colour_4="$_gb_blue"   # bright blue (accent)
tmux_conf_theme_colour_5="$_gb_yellow" # bright yellow (messages, mode)
tmux_conf_theme_colour_6="$_gb_bg0"    # bg — status-left S1 fg (dark on orange)
tmux_conf_theme_colour_7="$_gb_fg1"    # fg1 — status-left S2 fg
tmux_conf_theme_colour_8="$_gb_fg4"    # fg4 — status-left S3 fg
tmux_conf_theme_colour_9="$_gb_orange" # bright orange — status-left S1 bg
tmux_conf_theme_colour_10="$_gb_bg1"   # bg1 — status-left S2 bg
tmux_conf_theme_colour_11="$_gb_bg0"   # bg — status-left S3 bg
tmux_conf_theme_colour_12="$_gb_fg4"   # fg4 — status-right S1 fg
tmux_conf_theme_colour_13="$_gb_fg1"   # fg1 — status-right S2 fg
tmux_conf_theme_colour_14="$_gb_bg0"   # bg — status-right S3 fg
tmux_conf_theme_colour_15="$_gb_bg0"   # bg — status-right S1 bg
tmux_conf_theme_colour_16="$_gb_bg1"   # bg1 — status-right S2 bg
tmux_conf_theme_colour_17="$_gb_blue"  # bright blue — status-right S3 bg

# inactive panes dimmed; active pane restores true background
tmux_conf_theme_window_bg="$_gb_bg0s"
tmux_conf_theme_highlight_focused_pane=true
tmux_conf_theme_focused_pane_bg="$_gb_bg0"

# -- pane borders --------------------------------------------------------------

tmux_conf_theme_pane_border_style=thin
tmux_conf_theme_pane_border="$_gb_bg1"
tmux_conf_theme_pane_active_border="$_gb_blue"
%if #{>=:#{version},3.2}
tmux_conf_theme_pane_active_border="#{?pane_in_mode,${_gb_orange},#{?synchronize-panes,${_gb_bg1},${_gb_blue}}}"
%endif
tmux_conf_theme_pane_indicator="$_gb_blue"
tmux_conf_theme_pane_active_indicator="$_gb_blue"

# -- status line ---------------------------------------------------------------

tmux_conf_theme_message_fg="$tmux_conf_theme_colour_1"
tmux_conf_theme_message_bg="$tmux_conf_theme_colour_5"
tmux_conf_theme_message_attr="bold"
tmux_conf_theme_message_command_fg="$tmux_conf_theme_colour_5"
tmux_conf_theme_message_command_bg="$tmux_conf_theme_colour_1"
tmux_conf_theme_message_command_attr="bold"
tmux_conf_theme_mode_fg="$tmux_conf_theme_colour_1"
tmux_conf_theme_mode_bg="$tmux_conf_theme_colour_5"
tmux_conf_theme_mode_attr="bold"
tmux_conf_theme_status_fg="$tmux_conf_theme_colour_3"
tmux_conf_theme_status_bg="$tmux_conf_theme_colour_1"
tmux_conf_theme_status_attr="none"

tmux_conf_theme_terminal_title="#h ❐ #S ● #I #W"

# -- window tabs ---------------------------------------------------------------

tmux_conf_theme_window_status_fg="$tmux_conf_theme_colour_3"
tmux_conf_theme_window_status_bg="$tmux_conf_theme_colour_1"
tmux_conf_theme_window_status_attr="none"
tmux_conf_theme_window_status_format=" #I #W#{?window_zoomed_flag, 󰁌,}#{?window_bell_flag, 󰂞,} "

tmux_conf_theme_window_status_current_fg="$_gb_bg0"
tmux_conf_theme_window_status_current_bg="$_gb_green"
tmux_conf_theme_window_status_current_attr="bold"
tmux_conf_theme_window_status_current_format=" #I #W#{?window_zoomed_flag, 󰁌,}#{?window_bell_flag, 󰂞,} "

tmux_conf_theme_window_status_activity_fg="default"
tmux_conf_theme_window_status_activity_bg="default"
tmux_conf_theme_window_status_activity_attr="underscore"

tmux_conf_theme_window_status_bell_fg="$tmux_conf_theme_colour_5"
tmux_conf_theme_window_status_bell_bg="default"
tmux_conf_theme_window_status_bell_attr="blink,bold"

tmux_conf_theme_window_status_last_fg="$_gb_fg2"
tmux_conf_theme_window_status_last_bg="$_gb_bg1"
tmux_conf_theme_window_status_last_attr="none"

# -- separators ----------------------------------------------------------------

tmux_conf_theme_left_separator_main=""
tmux_conf_theme_left_separator_sub=""
tmux_conf_theme_right_separator_main=""
tmux_conf_theme_right_separator_sub=""

# -- status bar ----------------------------------------------------------------

tmux_conf_theme_status_left="  #S "
tmux_conf_theme_status_right="#{?client_prefix,#[bg=${_gb_red} fg=${_gb_bg0} bold] 󰌌 PREFIX ,}#{synchronized}  #{b:pane_current_path} |  #(cd #{pane_current_path}; git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '—') "

tmux_conf_theme_status_left_fg="$tmux_conf_theme_colour_6,$tmux_conf_theme_colour_7,$tmux_conf_theme_colour_8"
tmux_conf_theme_status_left_bg="$tmux_conf_theme_colour_9,$tmux_conf_theme_colour_10,$tmux_conf_theme_colour_11"
tmux_conf_theme_status_left_attr="bold,none,none"

tmux_conf_theme_status_right_fg="$tmux_conf_theme_colour_12,$tmux_conf_theme_colour_13,$tmux_conf_theme_colour_14"
tmux_conf_theme_status_right_bg="$tmux_conf_theme_colour_15,$tmux_conf_theme_colour_16,$tmux_conf_theme_colour_17"
tmux_conf_theme_status_right_attr="none,none,bold"

# -- indicators ----------------------------------------------------------------

tmux_conf_theme_pairing="⚇"
tmux_conf_theme_pairing_fg="none"
tmux_conf_theme_pairing_bg="none"
tmux_conf_theme_pairing_attr="none"

tmux_conf_theme_prefix="⌨"
tmux_conf_theme_prefix_fg="none"
tmux_conf_theme_prefix_bg="none"
tmux_conf_theme_prefix_attr="none"

tmux_conf_theme_root="!"
tmux_conf_theme_root_fg="none"
tmux_conf_theme_root_bg="none"
tmux_conf_theme_root_attr="bold,blink"

tmux_conf_theme_synchronized="⚏"
tmux_conf_theme_synchronized_fg="none"
tmux_conf_theme_synchronized_bg="none"
tmux_conf_theme_synchronized_attr="none"

# -- clock (<prefix> + t) ------------------------------------------------------

tmux_conf_theme_clock_colour="$tmux_conf_theme_colour_4"
tmux_conf_theme_clock_style="24"

# -- clipboard -----------------------------------------------------------------

tmux_conf_copy_to_os_clipboard=true

# -- overrides -----------------------------------------------------------------

set -g status-position bottom
set -g status-justify centre
set -g history-limit 50000
set -g mouse on
set -g status on
set -g status-interval 5

# NOTE: synchronized output (terminal-features sync) was removed — it caused
# iTerm2 to snap the viewport to the cursor position on every sync-end sequence,
# producing the "quick scroll down" during Claude/Ink re-renders. The original
# scroll-flash issue it was meant to fix is less disruptive than the snap.

# allow DCS passthrough so apps can send escape sequences directly to iTerm2
set -g allow-passthrough on

# prevent viewport from snapping to bottom when output arrives while scrolled
# (default is off but made explicit to survive oh-my-tmux option resets)
set -g scroll-on-output off

# auto-exit copy mode when switching to a different pane — prevents stale
# scrollback views in TUI apps (like Claude) that don't use the alternate screen buffer
set-hook -g after-select-pane 'if-shell -F "#{pane_in_mode}" "send-keys -X cancel"'

# prefix-active: session badge and active window tab shift to bright red
# uses #{?client_prefix} inline in status-left and window-status-current-format
#   idle:   $_gb_orange badge / $_gb_blue active tab
#   prefix: $_gb_red badge / $_gb_red active tab

bind m run "cut -c3- '#{TMUX_CONF}' | sh -s _toggle_mouse" \; display 'mouse #{?#{mouse},on,off}'
bind = select-layout -E \; display 'layout: rebalanced'

# -- which-key menus -----------------------------------------------------------
# show-wk-menu: command alias that wraps display-menu with consistent positioning
set -ga command-alias 'show-wk-menu=display-menu -x R -y P -T "#[align=centre,bold]"'

# root menu (prefix + Space)
set -g @wk_menu_root '\
  Run        "space" command-prompt \
  "Last win"   "tab" last-window \
  "Last pane"  "`"   last-pane \
  Copy         "c"   "show-wk-menu #{@wk_menu_copy}" \
  "" \
  +Windows     "w"   "show-wk-menu #{@wk_menu_windows}" \
  +Panes       "p"   "show-wk-menu #{@wk_menu_panes}" \
  +Buffers     "b"   "show-wk-menu #{@wk_menu_buffers}" \
  +Sessions    "s"   "show-wk-menu #{@wk_menu_sessions}" \
  +Client      "C"   "show-wk-menu #{@wk_menu_client}" \
  "" \
  "Toggle mouse" "m" "run \"cut -c3- '"'"'#{TMUX_CONF}'"'"' | sh -s _toggle_mouse\"" \
  "Edit config"  "e" "neww -n config \"${EDITOR:-vim} $TMUX_CONF_LOCAL\"" \
  "Reload config" "r" "source #{TMUX_CONF} ; display \"config reloaded\"" \
  "Fpp (F)"    "F"   "run \"cut -c3- '"'"'#{TMUX_CONF}'"'"' | sh -s _fpp '"'"'#{pane_id}'"'"' '"'"'#{pane_current_path}'"'"'\"" \
  Detach       "d"   detach \
  Time         "T"   clock-mode \
  "Show messages" "~" show-messages \
  +Keys        "?"   "list-keys -N"'

bind Space display-menu -x R -y P \
  -T "#[align=centre,bold]#[fg=green,align=centre,bold]tmux#[align=centre,bold]" \
  #{@wk_menu_root}

# windows submenu
set -g @wk_menu_windows '\
  "Last win"       "tab" last-window \
  Choose           "w"   "choose-tree -Zw" \
  Previous         "p"   previous-window \
  Next             "n"   next-window \
  New              "c"   "neww -c #{pane_current_path}" \
  "" \
  +Layout          "l"   "show-wk-menu #{@wk_menu_layout}" \
  "Split horiz"    "/"   "splitw -h -c #{pane_current_path}" \
  "Split vert"     "-"   "splitw -v -c #{pane_current_path}" \
  Rotate           "o"   "rotatew ; show-wk-menu #{@wk_menu_windows}" \
  "Rotate reverse" "O"   "rotatew -D ; show-wk-menu #{@wk_menu_windows}" \
  "" \
  "Prev window (C-h)"   "C-h" previous-window \
  "Next window (C-l)"   "C-l" next-window \
  "Swap left (C-S-H)"   "C-S-H" "swapw -t -1 ; selectw -t -1" \
  "Swap right (C-S-L)"  "C-S-L" "swapw -t +1 ; selectw -t +1" \
  "" \
  "Find (f)"       "f"   "command-prompt \"find-window -Z %%\"" \
  "Move (.)"       "."   "command-prompt -T target \"move-window -t %%\"" \
  Rename           "R"   "command-prompt -I \"#W\" \"renamew -- \\\"%%\\\"\"" \
  Kill             "X"   "confirm -p \"Kill window #W? (y/n)\" killw"'

# layout submenu
set -g @wk_menu_layout '\
  "Next layout"      "l" "nextl ; show-wk-menu #{@wk_menu_layout}" \
  Tiled              "t" "selectl tiled" \
  "Even horizontal"  "h" "selectl even-horizontal" \
  "Even vertical"    "v" "selectl even-vertical" \
  "Main horizontal"  "H" "selectl main-horizontal" \
  "Main vertical"    "V" "selectl main-vertical" \
  "" \
  "Rebalance (=)"    "=" "selectl -E"'

# panes submenu
set -g @wk_menu_panes '\
  Last             "tab" lastp \
  Choose           "p"   "displayp -d 0" \
  "" \
  Left             "h"   "selectp -L" \
  Down             "j"   "selectp -D" \
  Up               "k"   "selectp -U" \
  Right            "l"   "selectp -R" \
  "" \
  Zoom             "z"   "resizep -Z" \
  "Maximize (+)"   "+"   "run \"cut -c3- '"'"'#{TMUX_CONF}'"'"' | sh -s _maximize_pane '"'"'#{session_name}'"'"' '"'"'#D'"'"'\"" \
  "Rebalance (=)"  "="   "selectl -E" \
  +Resize          "r"   "show-wk-menu #{@wk_menu_resize}" \
  "" \
  "Swap left"      "H"   "swapp -t \"{left-of}\"" \
  "Swap down"      "J"   "swapp -t \"{down-of}\"" \
  "Swap up"        "K"   "swapp -t \"{up-of}\"" \
  "Swap right"     "L"   "swapp -t \"{right-of}\"" \
  "Swap prev (<)"  "<"   "swapp -U" \
  "Swap next (>)"  ">"   "swapp -D" \
  Break            "!"   break-pane \
  "" \
  Mark             "m"   "selectp -m" \
  Unmark           "M"   "selectp -M" \
  Capture          "C"   capture-pane \
  "Display (#)"    "q"   "displayp -d 0" \
  "Respawn pane"   "R"   restart-pane \
  Kill             "X"   "confirm -p \"Kill pane #P? (y/n)\" killp"'

# resize submenu (re-opens itself for repeated resizing)
set -g @wk_menu_resize '\
  Left             "h" "resizep -L ; show-wk-menu #{@wk_menu_resize}" \
  Down             "j" "resizep -D ; show-wk-menu #{@wk_menu_resize}" \
  Up               "k" "resizep -U ; show-wk-menu #{@wk_menu_resize}" \
  Right            "l" "resizep -R ; show-wk-menu #{@wk_menu_resize}" \
  "Left x10"       "H" "resizep -L 10 ; show-wk-menu #{@wk_menu_resize}" \
  "Down x10"       "J" "resizep -D 10 ; show-wk-menu #{@wk_menu_resize}" \
  "Up x10"         "K" "resizep -U 10 ; show-wk-menu #{@wk_menu_resize}" \
  "Right x10"      "L" "resizep -R 10 ; show-wk-menu #{@wk_menu_resize}"'

# copy submenu
set -g @wk_menu_copy '\
  "Enter copy mode" "c" copy-mode \
  "Copy to clipboard" "y" "run -b \"tmux save-buffer - | pbcopy\"" \
  "List buffers"   "#"   list-buffers'

# buffers submenu
set -g @wk_menu_buffers '\
  Choose           "b" "choose-buffer -Z" \
  List             "l" lsb \
  Paste            "p" pasteb \
  "Choose paste"   "P" "choose-buffer"'

# sessions submenu
set -g @wk_menu_sessions '\
  Choose           "s" "choose-tree -Zs" \
  New              "N" new \
  "New (C-c)"      "C-c" new-session \
  "Find (C-f)"    "C-f" "command-prompt -p find-session \"switchc -t %%\"" \
  "Last (BTab)"   "BTab" "switchc -l" \
  Rename           "r" rename'

# client submenu
set -g @wk_menu_client '\
  Choose           "c" "choose-client -Z" \
  Last             "l" "switchc -l" \
  Previous         "p" "switchc -p" \
  Next             "n" "switchc -n" \
  "" \
  Refresh          "R" refresh \
  +Plugins         "P" "show-wk-menu #{@wk_menu_plugins}" \
  Detach           "D" detach \
  Suspend          "Z" suspendc \
  "" \
  "Reload config"  "r" reload-config \
  Customize        "," "customize-mode -Z"'

# plugins submenu
set -g @wk_menu_plugins '\
  Install          "i" "run-shell $TMUX_PLUGIN_MANAGER_PATH/tpm/bindings/install_plugins" \
  Update           "u" "run-shell $TMUX_PLUGIN_MANAGER_PATH/tpm/bindings/update_plugins" \
  Clean            "c" "run-shell $TMUX_PLUGIN_MANAGER_PATH/tpm/bindings/clean_plugins"'

# drift check: warn on reload if bindings are missing from which-key menus
run-shell 'bash ~/.dotfiles/tmux/wk-drift-check.sh &'

# -- plugins -------------------------------------------------------------------

# disable vim-tmux-navigator's auto-bind of prefix+C-l to clear-screen
# so our C-l / C-h next/previous-window bindings survive plugin load
set -g @vim_navigator_prefix_mapping_clear_screen ''

set -g @plugin 'christoomey/vim-tmux-navigator'

set -g @plugin 'ggteixeira/tmux-immortal'

# oh-my-tmux has 'bind -n C-l' (clear-screen) as a direct command in tmux.conf:57.
# That direct command re-fires on every reload, outlasting the plugin because __apply_plugins
# only runs install/update/clean — never source_plugins — so vim-tmux-navigator.tmux is not
# re-sourced. #!important fires via _apply_important after __apply_plugins, reclaiming C-l.
bind -n C-l if-shell "ps -o state= -o comm= -t '#{pane_tty}' | grep -iqE '^[^TXZ ]+ +(\S+/)?g?\\.?(view|l?n?vim?x?|fzf)(diff)?(-wrapped)?$'" "send-keys 'C-l'" "select-pane -R" #!important
